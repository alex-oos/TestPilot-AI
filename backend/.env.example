# OpenAI Compatible AI Settings
# You can swap these out for Qwen, DeepSeek, Moonshot, Doubao, OpenAI, etc.

# === DeepSeek Example ===
LLM_API_KEY="sk-your-api-key-here"
LLM_BASE_URL="https://api.deepseek.com/v1"
LLM_MODEL="deepseek-chat"

