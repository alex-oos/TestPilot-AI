# ==========================================================================
# AI Test Platform - Backend 环境变量样例
# 用法: cp .env.example .env  然后按需填入真实密钥
# ==========================================================================

# ===================== 安全 / 鉴权 =====================
# 生产环境务必替换为 >=32 字节的高熵随机串，例如: openssl rand -hex 32
JWT_SECRET_KEY="please-change-this-to-a-strong-random-secret"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_DAYS=15

# ===================== LLM 模型 (OpenAI 兼容 API) =====================
# 支持: OpenAI / Qwen / DeepSeek / Moonshot / Doubao / LM Studio 等
# 当前实际使用配置（取消注释一组并填入真实 key）

# --- OpenAI ---
LLM_API_KEY="sk-your-openai-api-key-here"
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-5.4"

# --- LM Studio (本地推理) ---
# LLM_API_KEY="lm-studio"
# LLM_BASE_URL="http://127.0.0.1:1234/v1"
# LLM_MODEL="qwen/qwen3.5-9b"

# --- Qwen / 通义千问 (DashScope 兼容模式) ---
# LLM_API_KEY="sk-your-dashscope-api-key-here"
# LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# LLM_MODEL="qwen-turbo"

# LLM 调用守护
LLM_STEP_TIMEOUT_SECONDS=240
LLM_STEP_RETRIES=0
LLM_MAX_SOURCE_CHARS=32000
LLM_MAX_ANALYSIS_CHARS_FOR_STRATEGY=12000

# ===================== Embedding 模型 =====================
# 留空则降级为 hash embedding（仅供原型，强烈不推荐生产使用）
# 推荐: text-embedding-3-small (1536 维, 性价比高) / text-embedding-3-large (3072 维, 质量更高)
# 国产可选: BAAI/bge-m3 (多语言) 等通过 OpenAI 兼容代理调用
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=32
# 如果 embedding 服务和 LLM 不在同一个 base_url，可单独配置（留空则复用 LLM_*）
EMBEDDING_API_KEY=""
EMBEDDING_BASE_URL=""

# ===================== 向量数据库 =====================
# 可选: qdrant (推荐) | chroma (兼容旧数据)
VECTOR_DB_BACKEND="qdrant"

# Qdrant 嵌入式模式: 数据持久化到本地路径，无需 Docker
QDRANT_PATH="./data/qdrant_db"
# Qdrant 远程/Server 模式（设置后优先使用，可启用 payload index 与高并发）
# 例如本地 Docker:  docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=""
QDRANT_API_KEY=""
QDRANT_COLLECTION="test_case_kb_v3"

# 跨任务召回参数（真实 embedding 用 0.55；hash embedding 用 0.65+）
KB_SIMILARITY_THRESHOLD=0.55
KB_TOP_K=5

# ===================== MCP 文档服务 (Feishu / DingTalk) =====================
MCP_REQUEST_TIMEOUT_SECONDS=20

FEISHU_MCP_BASE_URL=""
FEISHU_MCP_INVOKE_PATH="/invoke"
FEISHU_MCP_TOOL_NAME="read_feishu_doc"
FEISHU_MCP_API_KEY=""

DINGTALK_MCP_BASE_URL=""
DINGTALK_MCP_INVOKE_PATH="/invoke"
DINGTALK_MCP_TOOL_NAME="read_dingtalk_doc"
DINGTALK_MCP_API_KEY=""

# Feishu CLI (安装方式: npm install -g @larksuite/cli)
FEISHU_USE_CLI=true
FEISHU_CLI_BIN="lark-cli"
FEISHU_CLI_PROFILE=""
FEISHU_CLI_AS="user"
FEISHU_CLI_TIMEOUT_SECONDS=20
FEISHU_AUTO_UPLOAD_XMIND=true
FEISHU_AUTO_WRITE_MINDMAP=true
FEISHU_WIKI_CHILD_OBJ_TYPE="docx"
FEISHU_DRIVE_FOLDER_TOKEN=""
FEISHU_DRIVE_DOMAIN="my.feishu.cn"

# ===================== 用例生成质量门禁 =====================
QUALITY_GATE_ENABLE=true
EXPECTED_RESULT_EMPTY_RATIO_THRESHOLD=0.35

# ===================== 应用基础 =====================
APP_BASE_URL="http://127.0.0.1:8001"
SQLITE_DB_PATH="./data/app.db"

# ===================== QA Skills（v2026-04-22 新增；v2026-04-22-r3 增强） =====================
# 基于开源项目 https://github.com/naodeng/awesome-qa-skills 的 SKILL 化 prompt 体系。
# system prompt 由 skill 提供「角色定位 + 方法论 + 最低覆盖清单」+ 项目内置 JSON Output Contract
# + 配置中心 extra_prompt_configs[role] 业务自定义补充。
USE_QA_SKILLS=true
QA_SKILLS_DIR=""
QA_SKILL_ANALYSIS=""
QA_SKILL_GENERATION=""
QA_SKILL_REVIEW=""
QA_SKILL_SUPPLEMENT=""
QA_SKILL_DISCOVER=""

# Few-shot：从 skill examples/ 中挑一段示例注入 prompt，提升步骤颗粒度
QA_SKILL_FEWSHOT_ENABLED=true
QA_SKILL_FEWSHOT_MAX_CHARS=1200

# Token 预估告警阈值；0 = 不限制；超阈值会在日志中 WARN
QA_SKILL_PROMPT_TOKEN_BUDGET=8000

# 业务自定义 extra_prompt 的最大字符数（防注入 / 防滥填）
QA_SKILL_EXTRA_PROMPT_MAX_CHARS=4000

# 智能路由（discover-testing）：根据需求关键词自动选择 generation skill
# 命中关键词时会切换到 api-test-pytest / mobile-testing / performance-testing 等
QA_SKILL_DISCOVER_ENABLED=false

# 三层降级开关：skill 拼装失败时是否回退到 prompts.py 中的旧硬编码 prompt
# false = 仅使用 [Output Contract + 业务自定义] 的两层降级
QA_SKILL_LEGACY_FALLBACK_ENABLED=true

# 项目级 overlay（多个用逗号分隔），目录在 backend/app/ai/skills/library/_overlays/<name>/
# 详见 library/_overlays/README.md
QA_SKILL_OVERLAY=""

# A/B 实验：generation 阶段并行跑 baseline + variant，仅记录指标对比
QA_SKILL_AB_ENABLED=false
QA_SKILL_AB_VARIANT_GENERATION=""

# 启动健康检查严格模式：true=任何 skill 失败/角色映射缺失立即抛错（推荐生产开启）
QA_SKILL_HEALTH_STRICT=false
# 是否将每次 LLM 调用的审计落库到独立 SQLite 表 skill_audits（关闭则只用进程内 ring buffer）
QA_SKILL_AUDIT_PERSIST=true
